    char s[100000]; 
    printf("Name: Adwait Shelare\n"); 
    printf("PRN: 25070521169\n"); 
 
    printf("Enter string: "); 
    scanf("%s", s); 
 
    if (isBalanced(s)) 
        printf("Output: true\n"); 
    else 
printf("Output: false\n"); 
return 0; 
}
