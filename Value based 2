#include <stdio.h> 
#include <stdbool.h> 
#define MAX 100000 
char stack[MAX]; 
int top = -1; 
void push(char c) { 
if (top < MAX - 1) 
stack[++top] = c; 
} 
char pop() { 
if (top == -1) 
return '\0'; 
return stack[top--]; 
} 
bool isEmpty() { 
return top == -1; 
} 
bool isMatch(char open, char close) { 
return (open == '(' && close == ')') || 
(open == '{' && close == '}') || 
(open == '[' && close == ']'); 
} 
bool isBalanced(char s[]) { 
top = -1; 
    for (int i = 0; s[i] != '\0'; i++) { 
        char ch = s[i]; 
 
        if (ch == '(' || ch == '{' || ch == '[') { 
            push(ch); 
        } 
        else if (ch == ')' || ch == '}' || ch == ']') { 
            if (isEmpty()) 
                return false; 
 
            char t = pop(); 
 
            if (!isMatch(t, ch)) 
                return false; 
        } 
    } 
 
    return isEmpty(); 
} 
 
